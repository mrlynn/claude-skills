# =============================================================================
# MongoDB DevRel Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# === MongoDB Connection ===
# Atlas connection string. Get from Atlas UI > Connect > Drivers
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# === Authentication (NextAuth v5) ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Must match your deployed URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# === Email (SMTP) ===
# SendGrid, Postmark, Mailgun, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM="Your App <noreply@yourdomain.com>"

# === Atlas Admin API ===
# Create API key at Atlas > Organization > Access Manager > API Keys
# Key needs "Organization Project Creator" + "Organization Member" roles
ATLAS_PUBLIC_KEY=your-atlas-public-key
ATLAS_PRIVATE_KEY=your-atlas-private-key
ATLAS_ORG_ID=your-atlas-org-id
# Optional: override the Atlas API base URL (defaults to https://cloud.mongodb.com/api/atlas/v2)
# ATLAS_BASE_URL=https://cloud.mongodb.com/api/atlas/v2

# === AI Services ===
# OpenAI — used for LLM generation (summaries, feedback synthesis)
OPENAI_API_KEY=sk-your-openai-key
# Voyage AI — used for embeddings (RAG pipeline, vector search)
VOYAGE_API_KEY=pa-your-voyage-key

# === Optional: Sentry Error Tracking ===
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# === Optional: File Uploads ===
# UPLOAD_MAX_SIZE_MB=10
# UPLOAD_DIR=./public/uploads
